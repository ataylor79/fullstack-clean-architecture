{
  "name": "@workout-app/api",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "NODE_ENV=test vitest run",
    "test:watch": "NODE_ENV=test vitest",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node -r tsx/cjs ./node_modules/knex/bin/cli.js migrate:latest --knexfile src/infrastructure/database/dbConfig.ts",
    "db:rollback": "node -r tsx/cjs ./node_modules/knex/bin/cli.js migrate:rollback --knexfile src/infrastructure/database/dbConfig.ts",
    "db:seed": "node -r tsx/cjs ./node_modules/knex/bin/cli.js seed:run --knexfile src/infrastructure/database/dbConfig.ts"
  },
  "dependencies": {
    "@workout-app/shared": "workspace:*",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "openapi-types": "^12.1.3",
    "pg": "^8.11.5",
    "resend": "^6.10.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.11.6",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/uuid": "^10.0.0",
    "supertest": "^7.2.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^1.6.0"
  }
}
